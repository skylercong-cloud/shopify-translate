NODE_ENV=production
TZ=Asia/Shanghai

# Public domain. Use a hostname only, without https://.
SITE_DOMAIN=docs.example.com
APP_ORIGIN=https://docs.example.com
APP_IMAGE_TAG=local

# PostgreSQL runs only on the internal Docker network.
POSTGRES_DB=shopify_docs
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
DATABASE_URL=postgres://app:replace-with-long-random-postgres-password@db:5432/shopify_docs

# Application session settings.
SESSION_DAYS=30

# Generate a high-entropy value and keep it outside Git history.
MODEL_KEY_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Shopify.dev source fetch limits.
SOURCE_REQUEST_CONCURRENCY=2
SOURCE_REQUEST_INTERVAL_MS=500
SOURCE_TIMEOUT_MS=20000
SOURCE_MAX_RESPONSE_BYTES=8388608

# Ingestion worker.
INGESTION_POLL_INTERVAL_MS=1000
INGESTION_LEASE_MS=120000

# Translation worker.
TRANSLATION_WORKER_ID=translation-1
TRANSLATION_POLL_INTERVAL_MS=1000
TRANSLATION_LEASE_MS=180000
TRANSLATION_HEARTBEAT_MS=60000
TRANSLATION_STALE_RESERVATION_MS=300000
TRANSLATION_STALE_REQUEST_MS=900000

# Daily local database backup.
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

